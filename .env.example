# ==============================================================================
# ASP Messina Web Services - Environment Variables
# ==============================================================================
# Copia questo file in .env e modifica i valori.
# Le variabili possono anche essere impostate direttamente nell'ambiente
# del processo (systemd, PM2, Docker, ecc.)
# ==============================================================================

# --- Generale ---
# NODE_ENV=production
# PORT=1337
BASE_URL=http://localhost:1337

# --- Email ---
# MAIL_ADDRESS=noreply@asp.messina.it

# --- Prometheus Metrics ---
# Endpoint: GET /metrics (basic auth HTTP)
METRICS_ENABLED=true
METRICS_USER=metrics
METRICS_PASS=

# --- Keycloak (opzionale, per SPID/CIE) ---
# KEYCLOAK_REALM_URL=https://auth.asp.messina.it/realms/asp
# KEYCLOAK_ALLOWED_CLIENTS=client1,client2

# --- Vault (opzionale, per crittografia dati sensibili) ---
# VAULT_SERVER_SECRET=
